# ADGE Tennis — environment template
# Copy to `.env.local` and fill in. NEVER commit real values — .env.local is gitignored.

# --- Local development (choose ONE way to authenticate the browser) ---
# A) Quick local test: paste a short-lived ephemeral Live token (starts with "AQ.")
#    Get one from Google AI Studio or your token-minting backend. Expires ~30 min.
VITE_GEMINI_TOKEN=

# B) Recommended (dev + prod): point the app at the backend token endpoint below,
#    which mints fresh tokens automatically. Leave VITE_GEMINI_TOKEN empty when using this.
# VITE_TOKEN_ENDPOINT=/api/token

# --- Model + cost config ---
VITE_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025
VITE_USD_TO_THB=36.5

# --- Live transport (SIT: Vertex server WS relay) ---
# VITE_LIVE_TRANSPORT unset/anything → AI-Studio ephemeral-token (AQ.) path above (prod default).
# VITE_LIVE_TRANSPORT=relay → browser talks to the SAME-ORIGIN server relay at
#   /api/live (server opens Vertex Live with ADC; NO token ever reaches the
#   browser). On SIT set:
#     VITE_LIVE_TRANSPORT=relay
#     VITE_GEMINI_LIVE_MODEL=gemini-live-2.5-flash   # bare id; server pins the full global resource path
# Optional relay overrides (defaults are fine for same-origin):
#   VITE_LIVE_RELAY_PATH=/api/live       # relay path (host inferred from window.location)
#   VITE_LIVE_RELAY_URL=                  # full ws(s):// URL override (dev/cross-origin only)

# --- Backend (server/) ONLY — never exposed to the browser ---
# VERTEX AI LIVE (SIT): the browser opens a same-origin WS to /api/live and the
# server relays it to the real Vertex Live session using ADC (Application Default
# Credentials) — NO key or ephemeral token in the browser. Set the project the
# relay pins the model to (defaults to ton-team). Model + location='global' are
# hard-pinned server-side (gemini-live-2.5-flash) and cannot be overridden by the
# client. Locally, auth via `gcloud auth application-default login` OR
# GOOGLE_APPLICATION_CREDENTIALS=<path to ton-team SA json>. The Cloud Run runtime
# SA needs roles/aiplatform.user.
GOOGLE_CLOUD_PROJECT=ton-team

# Long-lived Gemini API key (AIza…). Only used for the legacy /api/token ephemeral
# minter (AI Studio path). On Vertex Live via /api/live this is UNNECESSARY —
# leave it unset and /api/token returns a graceful bilingual 503. On Cloud Run set
# it via Secret Manager if you still need the token endpoint, NOT in this file.
# GEMINI_API_KEY=

# --- Cloud persistence (server/) ONLY ---
# GCS_BUCKET=            # clip/audio bucket (prod: ton-phet-clips; SIT: adge-tennis-sit-clips)
# DATABASE_URL=          # Supabase Postgres (IPv4 pooler, session mode)
# Postgres schema for row isolation on a SHARED database. Default 'public' =
# production. Set to 'sit' for the SIT environment so SIT rows never mix with prod.
# DB_SCHEMA=public       # sit for SIT
